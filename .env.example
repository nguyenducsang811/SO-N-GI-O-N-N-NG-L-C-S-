# AI Studio App Environment Variables

# Node Environment
NODE_ENV=production

# (Optional) Default Gemini API Key used by the server
# If provided, the UI might not require users to enter their own key
GEMINI_API_KEY=

# (Optional) Default Google Cloud configurations for Vertex AI
# These can be overridden by users in the application UI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
